*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:'Poppins',sans-serif;
    background:#0b0b0b;
    color:#ffffff;
}

/* Header */

header{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    padding:20px 8%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:rgba(0,0,0,.75);
    backdrop-filter:blur(12px);
    z-index:1000;
}

.logo h1{
    color:#e50914;
    font-size:2rem;
    font-weight:800;
}

nav{
    display:flex;
    gap:28px;
    align-items:center;
}

nav a{
    color:white;
    text-decoration:none;
    transition:.3s;
    font-weight:500;
}

nav a:hover{
    color:#e50914;
}

.subscribe{
    background:#e50914;
    padding:10px 18px;
    border-radius:6px;
}

.subscribe:hover{
    background:#ff2d38;
    color:white;
}

/* Hero */

.hero{
    height:100vh;
    display:flex;
    align-items:center;
    padding:0 8%;
    position:relative;
    background:
    linear-gradient(rgba(0,0,0,.55),rgba(0,0,0,.85)),
    url("../assets/hero.jpg") center/cover no-repeat;
}

.hero-content{
    max-width:650px;
    z-index:2;
}

.hero h2{
    font-size:4rem;
    line-height:1.1;
    margin-bottom:20px;
}

.hero p{
    font-size:1.2rem;
    color:#dddddd;
    line-height:1.8;
    margin-bottom:35px;
}

.buttons{
    display:flex;
    gap:18px;
}

.watch,
.info{
    text-decoration:none;
    padding:14px 28px;
    border-radius:8px;
    transition:.3s;
    font-weight:600;
}

.watch{
    background:#e50914;
    color:white;
}

.watch:hover{
    transform:translateY(-3px);
    box-shadow:0 0 25px rgba(229,9,20,.5);
}

.info{
    background:#2b2b2b;
    color:white;
}

.info:hover{
    background:#444;
}

/* Sections */

.section{
    padding:90px 8%;
}

.section h2{
    margin-bottom:30px;
    font-size:2.2rem;
}

/* Cards */

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
    gap:25px;
}

.card{
    background:#171717;
    border-radius:12px;
    overflow:hidden;
    transition:.35s;
    cursor:pointer;
}

.card:hover{
    transform:scale(1.05);
}

.card img{
    width:100%;
    height:300px;
    object-fit:cover;
}

.card h3{
    padding:18px;
}

/* Categories */

.categories{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:25px;
}

.category{
    background:#171717;
    padding:40px;
    border-radius:12px;
    text-align:center;
    transition:.3s;
}

.category:hover{
    background:#e50914;
    transform:translateY(-6px);
}

.category{
    font-size:2rem;
}

.category h3{
    margin-top:15px;
    font-size:1.2rem;
}

/* About */

.about p{
    color:#cccccc;
    font-size:1.1rem;
    line-height:2;
    max-width:850px;
}

/* Footer */

footer{
    text-align:center;
    padding:35px;
    background:#000;
    color:#888;
}

/* Scrollbar */

::-webkit-scrollbar{
    width:10px;
}

::-webkit-scrollbar-track{
    background:#111;
}

::-webkit-scrollbar-thumb{
    background:#e50914;
    border-radius:10px;
}

/* Responsive */

@media(max-width:900px){

header{
    flex-direction:column;
    gap:18px;
}

nav{
    flex-wrap:wrap;
    justify-content:center;
}

.hero{
    text-align:center;
    justify-content:center;
}

.hero h2{
    font-size:2.7rem;
}

.hero p{
    font-size:1rem;
}

.buttons{
    justify-content:center;
    flex-wrap:wrap;
}

.section{
    padding:70px 6%;
}

.card img{
    height:220px;
}

